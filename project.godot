[rendering]

textures/vram_compression/import_s3tc_bptc=true
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=3
textures/default_filters/anisotropic_filtering_level=3
environment/ssao/quality=3
environment/ssao/half_size=false
anti_aliasing/quality/msaa_3d=2
scaling_3d/fsr_sharpness=0.25
environment/defaults/default_clear_color=Color(0.0470588, 0.0627451, 0.113725, 1)
anti_aliasing/quality/screen_space_aa=1
anti_aliasing/quality/use_taa=true
